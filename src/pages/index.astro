---
import Layout from '../layouts/Layout.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
---

<Layout
  title="Beacon — RMM without the startup tax"
  description="Open-source, Cloudflare-native RMM agent. Self-host free forever on your own infrastructure, or use our hosted cloud with no minimums and no long-term lock-in."
>

<!-- ── Nav ──────────────────────────────────────────────────────────────── -->
<nav>
  <div class="logo">
    <span class="logo-mark"></span>
    RunBeacon
  </div>
  <div class="nav-right">
    <a href="https://github.com/synertek-cloud-services/beacon" class="nav-cta" target="_blank" rel="noopener noreferrer">
      Source on GitHub
    </a>
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle light and dark theme">
      <svg id="iconMoon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
      </svg>
      <svg id="iconSun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
        <circle cx="12" cy="12" r="4"/>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
      </svg>
    </button>
  </div>
</nav>

<!-- ── Hero ─────────────────────────────────────────────────────────────── -->
<section class="hero">
  <div class="radar-field" id="radarField" aria-hidden="true"></div>
  <div class="hero-content">
    <span class="eyebrow">● COMING SOON — JOIN THE WAITLIST</span>
    <h1>RMM that doesn't make you<br><span class="accent">commit before you're ready.</span></h1>
    <p class="sub">
      Beacon is an open-source, Cloudflare-native RMM agent built by an MSP that
      got tired of paying for enterprise licensing before the first client was even
      onboarded. Self-host it free on your own infrastructure, or use our hosted
      cloud and pay only for what you're actually running.
    </p>
    <WaitlistForm />
    <p class="form-note">Built by an MSP that got tired of paying too. No spam, one email when we launch.</p>
  </div>
</section>

<!-- ── Stat strip ────────────────────────────────────────────────────────── -->
<div class="stat-strip">
  <div>
    <div class="stat-num">$0</div>
    <div class="stat-label">to self-host, forever</div>
  </div>
  <div>
    <div class="stat-num">MIT</div>
    <div class="stat-label">licensed core agent</div>
  </div>
  <div>
    <div class="stat-num">Go</div>
    <div class="stat-label">lightweight, single binary</div>
  </div>
</div>

<!-- ── Cost comparison ───────────────────────────────────────────────────── -->
<section>
  <div class="section-inner">
    <div class="section-head">
      <span class="section-tag">// THE PROBLEM</span>
      <h2>The big vendors want a contract before you have clients.</h2>
      <p>
        Commercial RMM platforms front-load the cost. Licensing tiers, annual
        commitments, per-seat minimums — you're paying enterprise prices before
        you've proven the business. Beacon flips that: run the open-source agent
        yourself and pay nothing, or use our hosted cloud with no minimums and
        no long-term lock-in.
      </p>
    </div>

    <div class="compare">
      <div class="compare-col">
        <div class="compare-label">TYPICAL COMMERCIAL RMM</div>
        <div class="compare-price">$3–5</div>
        <div class="compare-unit">per endpoint, per month</div>
        <ul class="compare-list">
          <li><span class="mark">–</span> Cost scales with every device you add</li>
          <li><span class="mark">–</span> Closed source, vendor lock-in</li>
          <li><span class="mark">–</span> Licensing tiers gate basic features</li>
          <li><span class="mark">–</span> You never really own your monitoring stack</li>
        </ul>
      </div>
      <div class="compare-col highlight">
        <div class="compare-label">BEACON</div>
        <div class="compare-price">$0<span class="compare-price-or"> self-hosted</span></div>
        <div class="compare-unit">or pay-as-you-grow hosted cloud</div>
        <ul class="compare-list">
          <li><span class="mark">✓</span> Self-host free, forever, unlimited endpoints</li>
          <li><span class="mark">✓</span> Open source — read it, fork it, audit it</li>
          <li><span class="mark">✓</span> Hosted cloud with no minimums or annual contracts</li>
          <li><span class="mark">✓</span> Your data, your infrastructure, your call</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ── How it's built ────────────────────────────────────────────────────── -->
<section>
  <div class="section-inner">
    <div class="section-head">
      <span class="section-tag">// HOW IT'S BUILT</span>
      <h2>A small agent, a fast control plane.</h2>
      <p>
        No bloated Windows service eating half a gig of RAM. No monolithic
        backend to babysit. Beacon is built to be light on the endpoint and
        cheap to run at scale.
      </p>
    </div>

    <div class="pillars">
      <div class="pillar">
        <div class="pillar-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
        </div>
        <h3>Single Go binary</h3>
        <p>One small, self-updating agent per endpoint. No runtime dependencies, no background bloat, rollback built in if an update goes wrong.</p>
      </div>
      <div class="pillar">
        <div class="pillar-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 10h-1.26A8 8 0 109 20h9a5 5 0 000-10z"/>
          </svg>
        </div>
        <h3>Cloudflare-native control plane</h3>
        <p>Workers, D1, and Durable Objects handle orchestration — no servers to patch, scales down to zero when nothing's happening.</p>
      </div>
      <div class="pillar">
        <div class="pillar-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4l16 16M4 20L20 4"/>
            <circle cx="12" cy="12" r="9"/>
          </svg>
        </div>
        <h3>Consent-aware remote access</h3>
        <p>Tiered remote desktop with a privacy-mode system, so techs get in fast without users feeling watched.</p>
      </div>
    </div>
  </div>
</section>

<!-- ── Footer ────────────────────────────────────────────────────────────── -->
<footer>
  <div class="foot-left">
    <span class="logo-mark" style="width:14px; height:14px;" aria-hidden="true"></span>
    Beacon — an open-source project, built by Synertek Cloud Services
  </div>
  <div class="foot-links">
    <a href="https://github.com/synertek-cloud-services/beacon" target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href="mailto:hello@runbeacon.net">hello@runbeacon.net</a>
  </div>
</footer>

</Layout>

<style>
  /* ── Nav ──────────────────────────────────────────────────────────────── */
  nav {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px clamp(20px, 5vw, 64px);
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 18px;
    font-weight: 600;
    font-family: var(--font-display);
  }

  .logo-mark {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--amber);
    box-shadow: 0 0 0 4px var(--amber-dim), 0 0 16px 2px var(--amber);
    animation: pulse-mark 2.4s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-mark {
    0%, 100% { box-shadow: 0 0 0 4px var(--amber-dim), 0 0 16px 2px var(--amber); }
    50%       { box-shadow: 0 0 0 7px var(--amber-dim), 0 0 22px 4px var(--amber); }
  }

  .nav-right { display: flex; align-items: center; gap: 18px; }

  .theme-toggle {
    width: 38px;
    height: 38px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--text-dim);
    transition: color 0.15s, border-color 0.15s;
  }
  .theme-toggle:hover { color: var(--text); border-color: var(--text-faint); }
  .theme-toggle svg { width: 16px; height: 16px; }

  .nav-cta {
    font-size: 13px;
    font-weight: 500;
    padding: 9px 16px;
    border-radius: 7px;
    border: 1px solid var(--border);
    color: var(--text-dim);
    transition: color 0.15s, border-color 0.15s;
  }
  .nav-cta:hover { border-color: var(--text-faint); color: var(--text); }

  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    padding: clamp(60px, 10vw, 120px) clamp(20px, 5vw, 64px) 80px;
    display: grid;
    grid-template-columns: 1fr;
    justify-items: center;
    text-align: center;
    overflow: hidden;
  }

  .radar-field {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: grid;
    grid-template-columns: repeat(24, 1fr);
    gap: clamp(14px, 2vw, 26px);
    padding: 40px clamp(20px, 5vw, 64px);
    mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, black 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, black 30%, transparent 75%);
    opacity: 0.55;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 760px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--amber);
    background: var(--amber-dim);
    border: 1px solid color-mix(in srgb, var(--amber) 35%, transparent);
    padding: 6px 12px;
    border-radius: 20px;
    margin-bottom: 28px;
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(38px, 6vw, 68px);
    font-weight: 600;
    line-height: 1.06;
    letter-spacing: -0.02em;
    margin-bottom: 22px;
  }

  .hero h1 .accent { color: var(--amber); }

  .hero p.sub {
    font-size: clamp(16px, 2vw, 19px);
    color: var(--text-dim);
    max-width: 560px;
    margin: 0 auto 40px;
    line-height: 1.6;
  }

  .form-note {
    font-size: 12.5px;
    color: var(--text-faint);
    margin-top: 14px;
  }

  /* ── Stat strip ───────────────────────────────────────────────────────── */
  .stat-strip {
    display: flex;
    justify-content: center;
    gap: clamp(24px, 6vw, 72px);
    flex-wrap: wrap;
    padding: 0 20px 90px;
    text-align: center;
  }

  .stat-num {
    font-family: var(--font-mono);
    font-size: 26px;
    color: var(--amber);
    font-weight: 500;
  }

  .stat-label {
    font-size: 12.5px;
    color: var(--text-faint);
    margin-top: 4px;
  }

  /* ── Sections shared ──────────────────────────────────────────────────── */
  section {
    padding: 90px clamp(20px, 5vw, 64px);
    border-top: 1px solid var(--border);
  }

  .section-inner { max-width: 1080px; margin: 0 auto; }

  .section-head { max-width: 620px; margin-bottom: 56px; }

  .section-tag {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--teal);
    margin-bottom: 14px;
    display: block;
  }

  .section-head h2 {
    font-family: var(--font-display);
    font-size: clamp(26px, 3.5vw, 36px);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }

  .section-head p { color: var(--text-dim); font-size: 16px; line-height: 1.6; }

  /* ── Cost comparison ──────────────────────────────────────────────────── */
  .compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  @media (max-width: 720px) { .compare { grid-template-columns: 1fr; } }

  .compare-col { background: var(--surface); padding: 32px clamp(20px, 3vw, 36px); }
  .compare-col.highlight { background: var(--surface-2); }

  .compare-label {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-faint);
    margin-bottom: 18px;
  }
  .compare-col.highlight .compare-label { color: var(--amber); }

  .compare-price {
    font-family: var(--font-mono);
    font-size: 34px;
    margin-bottom: 6px;
  }

  .compare-price-or { font-size: 16px; color: var(--text-faint); }

  .compare-unit { font-size: 13px; color: var(--text-faint); margin-bottom: 26px; }

  .compare-list { list-style: none; }

  .compare-list li {
    font-size: 14.5px;
    color: var(--text-dim);
    padding: 9px 0;
    border-top: 1px solid var(--border);
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .compare-list li:first-child { border-top: none; }

  .compare-list li .mark { flex-shrink: 0; margin-top: 2px; }

  .compare-col.highlight .compare-list li .mark { color: var(--teal); }
  .compare-col:not(.highlight) .compare-list li .mark { color: var(--text-faint); }

  /* ── Pillars ──────────────────────────────────────────────────────────── */
  .pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  @media (max-width: 860px) { .pillars { grid-template-columns: 1fr; } }

  .pillar { background: var(--surface); padding: 32px 28px; }

  .pillar-icon {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: var(--amber-dim);
    color: var(--amber);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }

  .pillar-icon svg { width: 17px; height: 17px; }

  .pillar h3 {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 600;
    margin-bottom: 10px;
  }

  .pillar p { font-size: 14.5px; color: var(--text-dim); line-height: 1.6; }

  /* ── Footer ───────────────────────────────────────────────────────────── */
  footer {
    padding: 40px clamp(20px, 5vw, 64px);
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .foot-left {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--text-faint);
  }

  .foot-links { display: flex; gap: 22px; font-size: 13px; color: var(--text-faint); }
  .foot-links a:hover { color: var(--text-dim); }
</style>

<script>
  // Radar dot field
  const field = document.getElementById('radarField');
  if (field) {
    const COLS = 24, ROWS = 9;
    const dots: HTMLElement[] = [];
    for (let i = 0; i < COLS * ROWS; i++) {
      const d = document.createElement('div');
      d.style.cssText = 'width:3px;height:3px;border-radius:50%;background:var(--dot);justify-self:center;align-self:center;';
      field.appendChild(d);
      dots.push(d);
    }

    function sweepPulse() {
      const count = 5 + Math.floor(Math.random() * 6);
      const chosen = new Set<number>();
      while (chosen.size < count) chosen.add(Math.floor(Math.random() * dots.length));
      chosen.forEach(i => {
        dots[i].style.background = 'var(--dot-lit)';
        dots[i].style.boxShadow = '0 0 6px 1px var(--dot-lit)';
        setTimeout(() => {
          dots[i].style.background = 'var(--dot)';
          dots[i].style.boxShadow = '';
        }, 900 + Math.random() * 600);
      });
    }

    setInterval(sweepPulse, 700);
    sweepPulse();
  }
</script>
